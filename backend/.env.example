# Core backend
AUTH_SECRET_KEY=replace-with-a-long-random-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Existing AgriSarthi integrations (leave blank to use transparent local fallbacks)
DATAGOV_API_KEY=
AI_ADVISORY_API_URL=https://api.groq.com/openai/v1/chat/completions
AI_ADVISORY_API_KEY=
AI_ADVISORY_MODEL=llama-3.3-70b-versatile
CROP_KNOWLEDGE_API_URL=
RADAR_TILE_PROVIDER=rainviewer
NOMINATIM_USER_AGENT=agrisarthi-ai-local-dev

# AI Crop Pest and Disease Vision Analyzer
VISION_MODEL_DIR=model_artifacts
VISION_MODEL_REGISTRY=model_registry.json
VISION_STORAGE_DIR=storage/vision
VISION_DATASET_CANDIDATE_DIR=storage/dataset_candidates
VISION_DATABASE_PATH=vision.db
VISION_TREATMENT_KB=knowledge_base/treatments.json
VISION_MAX_UPLOAD_MB=12
VISION_MAX_IMAGES_PER_SESSION=8
VISION_REQUEST_TIMEOUT_SECONDS=90
VISION_RATE_LIMIT_PER_MINUTE=20
VISION_TEMP_RETENTION_HOURS=24
VISION_CONSENT_RETENTION_DAYS=30
VISION_DISEASE_THRESHOLD=0.55
VISION_PEST_THRESHOLD=0.40
VISION_CROP_THRESHOLD=0.60
VISION_LOW_CONFIDENCE_THRESHOLD=0.45
VISION_MIN_WIDTH=320
VISION_MAX_PIXELS=40000000
VISION_MIN_HEIGHT=320
VISION_BLUR_THRESHOLD=80
VISION_LOW_LIGHT_THRESHOLD=35
VISION_BRIGHT_THRESHOLD=235
VISION_ENABLE_WEATHER_CONTEXT=true
VISION_ALLOW_UNVERIFIED_COMMERCIAL_TREATMENTS=false
VISION_INFERENCE_DEVICE=auto
